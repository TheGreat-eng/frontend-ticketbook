# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env*.example

# secret and credential files
*.key
*.p8
*.p12
*.pfx
*.crt
*.cer
*.jks
*.keystore
id_rsa
id_ed25519
serviceAccountKey*.json
firebase-adminsdk*.json

# local tooling and editor state
.vscode/*
!.vscode/extensions.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
